rule delly_call:
    input:
        vg_mark = join(OUT_DIR, 'alignment', '{sample}_dupMark.bam'),
    output:
        sample_bcf = temp(join(OUT_DIR, 'calling', 'delly', '{sample}_delly.bcf'))
    params:
        dna = config['REFERENCE_FASTA']
    threads:
        8
    resources:
        mem_mb=12000
    log:
        join(OUT_DIR, 'logs', 'delly', '{sample}.delly_call.log')
    benchmark:
        join(OUT_DIR, 'benchmarks', 'delly', '{sample}.delly_call.benchmark.tsv')
    message:
        """--- SV calling for "{wildcards.sample}" with Delly."""
    conda:
        '../envs/delly.yml'
    shell:
        """
        delly call -g {params.dna} -o {output.sample_bcf} {input.vg_mark} > {log} 2>&1
        """

rule delly_merge:
    input:
        sample_bcf = expand(join(OUT_DIR, 'calling', 'delly', '{sample}_delly.bcf'), sample = SAMPLES)
    output:
        bcf = temp(join(OUT_DIR, 'calling', 'delly', 'raw_delly.bcf'))
    threads:
        8
    resources:
        mem_mb=12000
    log:
        join(OUT_DIR, 'logs', 'delly', 'delly_merge.log')
    benchmark:
        join(OUT_DIR, 'benchmarks', 'delly', 'delly_merge.benchmark.tsv')
    message:
        """--- Merging SV sites with Delly"""
    conda:
        '../envs/delly.yml'
    shell:
        """
        delly merge -o {output.bcf} {input.sample_bcf} > {log} 2>&1
        """

rule delly_geno:
    input:
        vg_mark = join(OUT_DIR, 'alignment', '{sample}_dupMark.bam'),
        bcf = join(OUT_DIR, 'calling', 'delly', 'raw_delly.bcf')
    output:
        sample_geno_bcf = join(OUT_DIR, 'calling', 'delly', '{sample}_geno.bcf')
    params:
        dna = config['REFERENCE_FASTA']
    threads:
        8
    resources:
        mem_mb=12000
    log:
        join(OUT_DIR, 'logs', 'delly', '{sample}.delly_geno.log')
    benchmark:
        join(OUT_DIR, 'benchmarks', 'delly', '{sample}.delly_geno.benchmark.tsv')
    message:
        """--- Genotyping SV across sample "{wildcards.sample}" with Delly."""
    conda:
        '../envs/delly.yml'
    shell:
        """
        delly call -g {params.dna} -v {input.bcf} -o {output.sample_geno_bcf} {input.vg_mark} > {log} 2>&1
        """

rule sv_merge:
    input:
        sample_geno_bcf = expand(join(OUT_DIR, 'calling', 'delly', '{sample}_geno.bcf'), sample = SAMPLES)
    output:
        geno_bcf = join(OUT_DIR, 'calling', 'delly', 'geno_delly.bcf')
    threads:
        24
    resources:
        mem_mb=32000
    log:
        join(OUT_DIR, 'logs', 'delly', 'delly_geno_merge.log')
    benchmark:
        join(OUT_DIR, 'benchmarks', 'delly', 'delly_geno_merge.benchmark.tsv')
    message:
        """--- Merging SV genotypes with BCFtools mapping."""
    conda:
        '../envs/bcftools.yml'
    shell:
        """
        
	bcftools merge -m id -O b -o {output.geno_bcf} {input.sample_geno_bcf} > {log} 2>&1
        """

rule delly_filter:
    input:
        geno_bcf = join(OUT_DIR, 'calling', 'delly', 'geno_delly.bcf')
    output:
        delly_bcf = join(OUT_DIR, 'calling', 'germline_delly.bcf')
    threads:
        8
    resources:
        mem_mb=12000
    log:
        join(OUT_DIR, 'logs', 'delly', 'delly_filter.log')
    benchmark:
        join(OUT_DIR, 'bemchmarks', 'delly', 'delly_filter.benchmark.tsv')
    message:
        """--- Applying germline SV filter for alignments. """
    conda:
        '../envs/delly.yml'
    shell:
        """
        delly filter -f germline -o {output.delly_bcf} {input.geno_bcf} > {log} 2>&1
        """
